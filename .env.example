# ============================================================
# Home Assistant MCP Server — Configuration
# ============================================================
# Copy this file to .env and fill in your values.

# Home Assistant URL
# Use your local IP when on LAN; Tailscale IP of the HA host when remote.
# Local:     http://172.17.217.241:8123
# Tailscale: http://100.121.40.159:8123
HA_URL=http://172.17.217.241:8123

# Home Assistant Long-Lived Access Token
# Generate at: HA → Profile (bottom-left) → Security → Long-Lived Access Tokens
HA_TOKEN=your_long_lived_access_token_here

# Host port that Docker maps to the container (change if 8080 is already in use)
MCP_PORT=8080
